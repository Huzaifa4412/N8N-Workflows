      "parameters": {
        "jsCode": "const rawPhone = String($json.candidate_details?.phone || '');\nlet phone = rawPhone.replace(/[()\\s.-]/g, '');\n\nif (phone.startsWith('00')) phone = '+' + phone.slice(2);\nif (!phone.startsWith('+') && phone.startsWith('92')) phone = '+' + phone;\nif (!phone.startsWith('+') && phone.startsWith('0')) phone = '+92' + phone.slice(1);\n\nconst canCallCandidate = /^\\+[1-9]\\d{9,14}$/.test(phone);\n\nreturn [{\n  json: {\n    ...$json,\n    candidate_details: {\n      ...$json.candidate_details,\n      phone\n    },\n    can_call_candidate: canCallCandidate\n  }\n}];"
      },
