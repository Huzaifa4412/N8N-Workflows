      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of $input.all()) {\n  const binary = item.binary || {};\n\n  for (const key of Object.keys(binary)) {\n    const file = binary[key];\n    const fileName = file.fileName || key;\n    const mimeType = (file.mimeType || '').toLowerCase();\n\n    if (fileName.toLowerCase().endsWith('.pdf') || mimeType.includes('pdf')) {\n      output.push({\n        json: {\n          gmail_id: item.json.id || '',\n          thread_id: item.json.threadId || '',\n          subject: item.json.Subject || item.json.subject || '',\n          from: item.json.From || item.json.from || '',\n          to: item.json.To || item.json.to || '',\n          file_name: fileName\n        },\n        binary: {\n          data: file\n        }\n      });\n    }\n  }\n}\n\nreturn output;"
      },
